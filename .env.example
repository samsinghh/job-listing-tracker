# Copy this file to `.env.local` and fill in your values.
# `.env.local` is gitignored — keep your real credentials only there.
#
# Gmail requires an *App Password* (not your normal password):
#   Google Account > Security > 2-Step Verification > App passwords
# Generate one, then paste the 16-character value below (spaces optional).

export IW_SMTP_USER="youraddress@gmail.com"
export IW_SMTP_PASSWORD="your16charapppassword"

# Where to send notifications. Overrides `email.to` in config.yaml, so the
# committed config can keep a placeholder while your real address stays here.
# Comma-separate for multiple recipients.
export IW_EMAIL_TO="youraddress@gmail.com"
